---
import '../app.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'movie' | 'tv';
  item?: any;
  season?: string;
  episode?: string;
  canonical?: string;
}


import { getSeoMetadata } from '../lib/seo/engine';

const { title, description = "موقع معاك سيما لمشاهدة الافلام والمسلسلات", type, item, season, episode, canonical } = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://ma3ak.top';
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

const meta = getSeoMetadata({
  item,
  type: type as any,
  season,
  episode,
  siteUrl,
  currentUrl,
  isWatchPage: Astro.url.pathname.includes('/watch/')
});

const pageTitle = meta.title;


---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{pageTitle}</title>
    
    <SEO title={title} description={description} type={type} item={item} season={season} episode={episode} canonical={canonical} />

    <script is:inline>
      /** 
       * Triple-Check Adblock Detection (Advanced Strategy)
       * 1. Element Honeypot Check
       * 2. Network Ad-Server Fetch Check
       * 3. CSS Class Visibility Check
       */
      async function checkAdblock() {
        const overlay = document.getElementById('adblock-overlay');
        const content = document.getElementById('main-content-wrap');
        
        let isBlocked = false;

        // --- Check 1: Network Check (Fetch Google Ads script) ---
        try {
          const adRequest = new Request('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js', { method: 'HEAD', mode: 'no-cors' });
          await fetch(adRequest).catch(() => { isBlocked = true; });
        } catch (e) {
          isBlocked = true;
        }

        // --- Check 2: Element Honeypot Check ---
        if (!isBlocked) {
          const ad = document.createElement('div');
          ad.className = 'Ad ads ad-banner ads-label pub_300x250 pub_728x90 text-ads adsense';
          ad.style.cssText = 'height:1px !important; width:1px !important; position:absolute !important; top:-1000px !important; left:-1000px !important;';
          document.body.appendChild(ad);
          
          await new Promise(r => setTimeout(r, 100)); // Short delay for blocker to react
          
          const styles = window.getComputedStyle(ad);
          if (ad.offsetHeight === 0 || ad.clientHeight === 0 || styles.display === 'none' || styles.visibility === 'hidden') {
            isBlocked = true;
          }
          ad.remove();
        }

        // --- Action if Detected ---
        if (isBlocked) {
          document.documentElement.classList.add('adblock-detected');
          document.body.classList.add('adblock-detected');
          
          if (overlay) {
            overlay.classList.remove('hidden');
            overlay.style.display = 'flex';
          }
          if (content) {
            content.style.pointerEvents = 'none';
          }
        }
      }

      // Initial check and periodic re-check for dynamic blockers
      document.addEventListener('DOMContentLoaded', checkAdblock);
      window.addEventListener('load', checkAdblock);
      setTimeout(checkAdblock, 2000);
    </script>
  </head>
  <body class="bg-zinc-950 text-white font-sans min-h-screen antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[999999] focus:p-4 focus:bg-primary focus:text-white font-bold">تخطي إلى المحتوى الرئيسي</a>
    
    <div id="adblock-overlay" class="fixed inset-0 z-[999999] bg-zinc-950/95 hidden flex-col items-center justify-center text-center p-6 backdrop-blur-3xl transition-all duration-700">
      <div class="max-w-2xl bg-zinc-900/80 p-12 rounded-3xl border border-zinc-800 shadow-[0_0_50px_rgba(239,68,68,0.2)]">
        <div class="relative inline-block mb-8">
          <div class="absolute inset-0 bg-red-500 blur-2xl opacity-20 animate-pulse"></div>
          <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-red-500 relative drop-shadow-[0_0_10px_rgba(239,68,68,0.6)]"><path d="M12 2L2 22h20L12 2z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        
        <div class="text-4xl font-black text-white mb-6 tracking-tight leading-tight">
          نعتذر، تم اكتشاف <span class="text-red-500">مانع إعلانات</span>
        </div>
        
        <p class="text-xl text-zinc-400 mb-10 leading-relaxed font-medium">
          موقع <span class="text-white font-bold">معاك سيما</span> يقدم خدماته مجاناً بالكامل بفضل الإعلانات. يرجى التكرم بتعطيل مانع الإعلانات لتتمكن من متابعة المشاهدة ودعم استمرارية الموقع.
        </p>
        
        <div class="flex justify-center">
          <button onclick="window.location.reload()" class="bg-red-600 hover:bg-red-700 text-white px-12 py-5 rounded-2xl font-black text-xl transition-all shadow-[0_10px_40px_rgba(220,38,38,0.4)] hover:shadow-red-600/60 hover:-translate-y-1 active:scale-95">
            لقد قمت بالتعطيل، أعد التحميل الآن
          </button>
        </div>
        
        <p class="mt-8 text-zinc-600 text-sm italic">
          شكراً لتفهمك ودعمك المتواصل لنا 🤍
        </p>
      </div>
    </div>

    <div id="main-content-wrap" class="transition-all duration-700">
    <header role="banner" class="p-4 border-b border-zinc-800 sticky top-0 bg-zinc-950/80 backdrop-blur-xl z-50">
      <div class="container mx-auto flex justify-between items-center">
        <div class="flex items-center gap-12">
           <a href="/" aria-label="الصفحة الرئيسية لموقع معاك سيما" class="text-3xl font-black text-primary tracking-tighter hover:scale-105 transition-transform duration-300">معاك <span class="text-white">سيما</span></a>
           
           <!-- Desktop Nav -->
           <nav class="hidden md:flex items-center gap-8 text-sm font-black uppercase tracking-wider text-zinc-400">
              <a href="/movie" class="hover:text-primary transition-colors flex items-center gap-2">الافلام</a>
              <a href="/tv" class="hover:text-primary transition-colors flex items-center gap-2">المسلسلات</a>
              <a href="/categories" class="px-4 py-2 bg-zinc-900 rounded-xl border border-zinc-800 hover:border-primary/50 hover:text-white transition-all">الأقسام</a>
           </nav>
        </div>
        
        <!-- Search Quick Link -->
        <a href="/search" aria-label="البحث في الموقع" class="p-2.5 bg-zinc-900 rounded-xl border border-zinc-800 text-zinc-500 hover:text-primary hover:border-primary/40 transition-all">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </a>
      </div>
    </header>
    
    <main id="main-content" role="main" class="container mx-auto p-4">
      <slot />
    </main>

    <footer class="p-4 border-t border-zinc-800 mt-8 text-center text-zinc-400">
      <p>&copy; {new Date().getFullYear()} معاك سيما. جميع الحقوق محفوظة.</p>
    </footer>
    </div>
  </body>
</html>
