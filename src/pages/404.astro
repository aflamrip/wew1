---
import Layout from '../layouts/Layout.astro';
import SmartSearch from '../components/ui/SmartSearch.svelte';
import { CDN_URLS, getPrefix, getDynamicContent } from '../lib/constants';

// SSR Fetch: Suggest 8 random items (mix of ar/en movies and series)
let suggestions = [];
try {
  const allMovies = await getDynamicContent('movie', 1); // Get 1st index for faster suggestions
  const allSeries = await getDynamicContent('tv', 1);
  
  suggestions = [
    ...allMovies.filter(m => m.data.lang === 'ar').slice(0, 3),
    ...allMovies.filter(m => m.data.lang === 'en').slice(0, 3),
    ...allSeries.filter(s => s.data.lang === 'ar').slice(0, 3),
    ...allSeries.filter(s => s.data.lang === 'en').slice(0, 3)
  ].sort(() => Math.random() - 0.5).slice(0, 8);
} catch (e) {
  console.error("Suggestions fetch error:", e);
  suggestions = [];
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=14400');
---

<Layout title="الصفحة غير موجودة - 404 | معاك سيما">
  <div class="space-y-16 py-12 px-4 max-w-7xl mx-auto">
    
    <!-- Hero Error Section -->
    <div class="flex flex-col items-center justify-center text-center space-y-8 bg-zinc-900/20 py-12 rounded-[40px] border border-zinc-800 shadow-3xl relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-amber-500/5 -z-10 blur-3xl"></div>
      
      <div class="relative group">
        <h1 class="text-[140px] leading-none font-black bg-clip-text text-transparent bg-gradient-to-tr from-white via-primary to-amber-400 drop-shadow-2xl opacity-90 pb-2">
          404
        </h1>
        <div class="absolute -inset-10 blur-3xl bg-primary/20 rounded-full -z-10 animate-pulse transition-all group-hover:scale-125 group-hover:bg-primary/30"></div>
      </div>
      
      <div class="space-y-4 max-w-2xl">
        <h2 class="text-4xl md:text-5xl text-zinc-100 font-black tracking-tight leading-normal">عذراً، المحتوى المطلوب غير موجود.</h2>
        <p class="text-zinc-500 max-w-xl mx-auto text-lg font-medium leading-relaxed pt-2">لا تقلق، قد يكون الرابط خاطئاً أو تم تحديثه. ابحث عما تفضله باستخدام محرك البحث الذكي أو استكشف مقترحاتنا المميزة بالأسفل.</p>
      </div>
      
      <!-- Fast Direct Search Bar -->
      <div class="w-full max-w-3xl mx-auto pt-6 px-4">
         <form action="/movie" method="GET" class="relative group">
            <input 
              type="text" 
              name="q" 
              placeholder="ابحث عن الأفلام أو المسلسلات بالاسم العربي أو الإنجليزي..."
              class="w-full bg-zinc-900 border-2 border-zinc-700/80 rounded-[28px] py-6 pr-16 pl-6 text-white outline-none focus:border-primary focus:ring-8 focus:ring-primary/10 transition-all placeholder:text-zinc-500 font-bold text-xl shadow-2xl"
            />
            <div class="absolute right-6 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-primary transition-colors">
               <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
            <button type="submit" class="absolute left-4 top-1/2 -translate-y-1/2 bg-zinc-800 hover:bg-primary text-zinc-300 hover:text-white px-6 py-2.5 rounded-2xl font-black text-sm transition-all border border-zinc-700">بحث</button>
         </form>
      </div>
    </div>

    <!-- Dynamic Suggestions Section -->
    <section class="space-y-10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 px-4">
        <div class="flex items-center gap-4">
           <div class="p-3 bg-amber-500/10 text-amber-500 rounded-2xl border border-amber-500/20">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 16.3c-2.2-.8-3.1-2.9-2-4.7C4.4 9.9 6.1 9 8 9c2.3 0 4 2 4 4v1c0 2 1 3 3 3"></path><path d="M19 8v.01"></path><circle cx="12" cy="12" r="10"></circle></svg>
           </div>
           <h3 class="text-3xl font-black text-white">مقترحات قد تعجبك</h3>
        </div>
        <a href="/" class="px-6 py-2 bg-zinc-900 border border-zinc-800 text-zinc-400 hover:text-white hover:border-primary transition-all rounded-xl text-sm font-black">العودة للرئيسية</a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-4 gap-8 px-4">
        {suggestions.map(item => {
          const isMovie = item.data.type === 'movie';
          const isArabic = item.data.lang === 'ar';
          const suffix = !isArabic ? 'مترجم' : (isMovie ? 'كامل' : 'متوفر');
          const badgeColor = isArabic ? 'bg-primary' : 'bg-blue-600';
          const itemTitle = !isArabic && item.data.arabic_title ? item.data.title : (item.data.arabic_title || item.data.title);

          return (
            <a href={`/${isMovie ? 'movie' : 'tv'}/${item.data.slug}`} class="group relative block">
               <div class="aspect-[2/3] rounded-3xl overflow-hidden relative shadow-2xl border border-zinc-800 group-hover:border-primary/40 transition-all duration-500 hover:-translate-y-2">
                  <img 
                    src={`${CDN_URLS.STATIC}/${isMovie ? 'movies' : 'tv'}/${getPrefix(item.id)}/${item.id}/${item.id}.webp`}
                    alt={item.data.title}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-80 group-hover:opacity-100"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent opacity-90"></div>
                  
                  <div class="absolute top-4 right-4 z-20">
                     <span class={`${badgeColor} text-white px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider shadow-lg ring-1 ring-black/50`}>
                       {suffix}
                     </span>
                  </div>

                  <div class="absolute bottom-0 p-5 w-full z-20 translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                    <div class="flex justify-between items-center text-[11px] font-bold text-zinc-400 mb-2">
                      <span class="bg-zinc-950/50 px-2.5 py-1 rounded-full backdrop-blur-md border border-zinc-800/80">{item.data.year}</span>
                    </div>
                    <h4 class="font-black text-white group-hover:text-primary transition-colors text-base line-clamp-1 leading-tight mb-1">
                      {itemTitle}
                    </h4>
                    <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest">{isMovie ? 'فيلم' : 'مسلسل'}</p>
                  </div>
               </div>
            </a>
          );
        })}
      </div>
    </section>

  </div>
</Layout>
